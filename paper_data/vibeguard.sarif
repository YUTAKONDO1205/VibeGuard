                  }
                }
              }
            }
          ],
          "properties": {
            "confidence": "high",
            "severity": "critical",
            "tags": [
              "rce",
              "ai-prone"
            ]
          }
        },
        {
          "ruleId": "VG-AUTH-003",
          "level": "error",
          "message": {
            "text": "Hard-coded placeholder values like \"dummy_token\", \"test_password\", \"changeme\" frequently survive the trip to production."
          },
          "locations": [
            {
              "physicalLocation": {
                "artifactLocation": {
                  "uri": "auth_bypass.py"
                },
                "region": {
                  "startLine": 7,
